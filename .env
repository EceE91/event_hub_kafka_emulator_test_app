# Kafka/Event Hub Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=local-app
KAFKA_TOPIC=eh1
KAFKA_CONSUMER_GROUP=my-app-consumer

# Event Hub Connection String
EVENT_HUB_CONNECTION_STRING=Endpoint=sb://localhost;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SAS_KEY_VALUE;UseDevelopmentEmulator=true;

# SSL Settings
KAFKA_SSL=false

